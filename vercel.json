{
  "version": 2,
  "public": "SyntaxSlayer",
  "builds": [
    {
      "src": "SyntaxSlayer/syntax-slayer-backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/save-score",
      "dest": "SyntaxSlayer/syntax-slayer-backend/server.js",
      "methods": ["POST"]
    },
    {
      "src": "/leaderboard/(.*)",
      "dest": "SyntaxSlayer/syntax-slayer-backend/server.js",
      "methods": ["GET"]
    },
    {
      "src": "/clear-leaderboard",
      "dest": "SyntaxSlayer/syntax-slayer-backend/server.js",
      "methods": ["DELETE"]
    },
    {
      "src": "/(.*)",
      "dest": "SyntaxSlayer/$1"
    }
  ]
}
